# OS
.DS_Store

# Org-specific config (contains private domain names)
scripts/readwise_skip_domains.txt

# Personal data (PRIVATE — never commit)
# Raw note snapshots
reflect-*/
# Reflection index (legacy) with personal goals/summaries
index/
!index/.gitkeep
# Profile with personal identity/goals/expertise
profile/
# Personal reference material (examples, sensitive context)
personal/
!personal/.gitkeep
# Reader persona (personal data)
reader_persona.md
# Paper review methodology (functional locally, kept out of public repo)
.claude/commands/paper-review.md
# Handoff plans with personal note references
handoffs/
# Local MCP server URL
.mcp.json
# Codex session state
.context/

# Build state
*.build-state.json

# Python (venv symlink points to ~/.cache/reflectl/.venv, outside Cloud Storage)
.venv
__pycache__/
*.pyc

# Device-dependent config (each machine gets its own)
semantic.toml

# Local-first data layer (symlink or subdir; never commit the vault)
zk

# /sync idempotency ledger (tracks which wiki entries have been pushed to Reflect)
zk/.sync-manifest.json
